# EditorConfig — https://editorconfig.org
# Honored by Qt Creator and VS Code (both used in this repo).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C++ / Objective-C++ — matches .clang-format
[*.{c,cpp,h,hpp,mm,m}]
indent_size = 4

[*.qml]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{cmake,txt}]
indent_size = 4

[CMakeLists.txt]
indent_size = 4

[*.sh]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
