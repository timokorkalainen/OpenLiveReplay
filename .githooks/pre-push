#!/usr/bin/env bash
# Pre-push hook: a FAST local pre-flight (~5 min). GitHub CI is now the
# comprehensive gate -- macOS + Linux + Windows builds, the unit suite, the
# playback e2e, and the clang ASan/UBSan/TSan sanitizer passes all run there (see
# .github/workflows/ci.yml). This hook just catches the COMMON failures before
# they reach CI, on the current platform:
#   * build the host (engine + app + test harnesses) with -Werror
#   * the transport x codec "delivery-gate" matrix (RTMP/SRT x h264/h265) --
#     local-only coverage CI does not run
#   * clang-tidy on changed first-party C++
#   * the fast unit label (-L ci)
# A build / unit / clang-tidy failure blocks the push.
#
# The heavier e2e + sanitizer + iOS gates are OPT-IN (OLR_PREPUSH_FULL=1) -- run
# them to reproduce a CI failure locally, or before a risky native/threading change.
#
# The gate HARD-FAILS the push if delivery tooling is missing (it does NOT
# silently skip): ffmpeg, ffprobe, srt-live-transmit, a Python 3, an H.264 and an
# HEVC encoder in ffmpeg, and the Qt host kit. Install on macOS with:
#   brew install ffmpeg srt
#
# Do NOT bypass this gate with `git push --no-verify` -- it is the project's
# required pre-flight. To skip a gate that cannot run on the current
# platform/toolchain, use the per-gate SKIP_* flags below.
#
# Triggers / flags:
#   git push                  -> build + delivery + clang-tidy + unit (BLOCKING default)
#   OLR_PREPUSH_SKIP=1 push   -> emergency bypass ONLY (never use git push --no-verify;
#                                prefer the per-gate SKIP_* flags for platform skipping)
#   OLR_PREPUSH_LIGHT=1 push  -> delivery matrix ONLY (skip clang-tidy + unit)
#   SKIP_UNIT=1 / SKIP_TIDY=1  -> skip one default gate
#   OLR_PREPUSH_FULL=1 push   -> ALSO run e2e + ASan/UBSan + TSan + full CTest matrix + iOS
#                                (skip parts: SKIP_E2E=1 / SKIP_ASAN=1 / SKIP_TSAN=1 /
#                                 SKIP_FULL_TESTS=1 / SKIP_IOS_BUILD=1)
#
# Tunables:
#   OLR_E2E_CLIP_SECONDS  (default 5)               e2e / delivery clip length
#   QT_HOST_PREFIX        (default ~/Qt/6.10.1/macos)
#   QT_IOS_PREFIX         (default ~/Qt/6.10.1/ios)  used only by OLR_PREPUSH_FULL
#
# Enable the hook once per clone:  git config core.hooksPath .githooks
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ "${OLR_PREPUSH_SKIP:-0}" = "1" ]; then
    echo "[pre-push] OLR_PREPUSH_SKIP=1 - skipping the delivery gate. Push proceeding." >&2
    exit 0
fi

QT_HOST_PREFIX="${QT_HOST_PREFIX:-${QT_ROOT_DIR:-$HOME/Qt/6.10.1/macos}}"
CLIP_SECONDS="${OLR_E2E_CLIP_SECONDS:-5}"
DELIVERY_BUILD_DIR="${OLR_PREPUSH_DELIVERY_BUILD_DIR:-build/prepush-delivery}"

# --- 1. Preflight: hard-fail (block the push) if delivery tooling is missing ---
preflight_fail=0
note_missing() { echo "[pre-push] MISSING: $1" >&2; preflight_fail=1; }

for tool in ffmpeg ffprobe srt-live-transmit; do
    command -v "$tool" >/dev/null 2>&1 || note_missing "$tool not found on PATH"
done

# Python 3 SPECIFICALLY (mirror rtmp_lib.sh:rtmp_find_python3) -- a Python-2-only
# `python`/`py` would pass a bare presence check but make the RTMP cells SKIP.
have_python3() {
    local c
    for c in python3 python; do
        if command -v "$c" >/dev/null 2>&1 \
            && "$c" -c 'import sys; sys.exit(0 if sys.version_info[0] == 3 else 1)' >/dev/null 2>&1; then
            return 0
        fi
    done
    if command -v py >/dev/null 2>&1 \
        && py -3 -c 'import sys; sys.exit(0 if sys.version_info[0] == 3 else 1)' >/dev/null 2>&1; then
        return 0
    fi
    return 1
}
have_python3 || note_missing "Python 3 not found (needed by the RTMP fixture server)"

# Encoder checks need ffmpeg itself; skipped (ffmpeg already flagged above) if absent.
if command -v ffmpeg >/dev/null 2>&1; then
    ENCODERS="$(ffmpeg -hide_banner -encoders 2>/dev/null || true)"
    # H.264: the scripts accept only libx264 or h264_mf (see olr_h264_vcodec_args).
    if ! printf '%s\n' "$ENCODERS" | grep -Eq '(^|[[:space:]])(libx264|h264_mf)[[:space:]]'; then
        note_missing "no usable H.264 encoder (need libx264 or h264_mf) in ffmpeg"
    fi
    # HEVC: run_rtmp_hevc_smoke.sh only tries hevc_videotoolbox then libx265; the
    # SRT-HEVC cell accepts libx265 or any hevc_*. Require EITHER libx265 or
    # hevc_videotoolbox (an OR -- either one alone satisfies both cells); this is
    # the tightest check that still guarantees both HEVC cells run, never skip.
    if ! printf '%s\n' "$ENCODERS" | grep -Eq '(^|[[:space:]])(libx265|hevc_videotoolbox)[[:space:]]'; then
        note_missing "no usable HEVC encoder (need libx265 or hevc_videotoolbox) in ffmpeg"
    fi
fi

[ -d "$QT_HOST_PREFIX" ] || note_missing "Qt host kit not found at $QT_HOST_PREFIX"

if [ "$preflight_fail" -ne 0 ]; then
    cat >&2 <<EOF
[pre-push] Delivery gate cannot run -- required tooling is missing (see above).
[pre-push]   macOS install:  brew install ffmpeg srt
[pre-push]   Qt host kit:    set QT_HOST_PREFIX (currently $QT_HOST_PREFIX)
[pre-push] Emergency bypass: OLR_PREPUSH_SKIP=1 git push   (or git push --no-verify)
EOF
    exit 1
fi

# --- 2. Build the current-platform host (engine + app + test harnesses) -------
# -DOLR_WERROR=ON makes this the clang -Werror compile gate (mirrors what the
# macOS build-test CI job used to enforce); the same build dir is reused by the
# native unit/e2e and clang-tidy gates below.
echo "[pre-push] Building current-platform host in ${DELIVERY_BUILD_DIR}..."
cmake -S . -B "$DELIVERY_BUILD_DIR" -G Ninja \
    -DCMAKE_BUILD_TYPE=Debug \
    -DCMAKE_PREFIX_PATH="$QT_HOST_PREFIX" \
    -DOLR_WERROR=ON \
    -DOLR_BUILD_TESTS=ON >/dev/null
cmake --build "$DELIVERY_BUILD_DIR"

# --- 3. Sanity: the delivery-gate label must resolve to exactly 4 cells --------
EXPECTED_CELLS=4
ACTUAL_CELLS="$(ctest --test-dir "$DELIVERY_BUILD_DIR" -L delivery-gate -N \
    | awk '/Total Tests:/ {print $NF}')"
if [ "${ACTUAL_CELLS:-0}" -ne "$EXPECTED_CELLS" ]; then
    echo "[pre-push] Delivery gate misconfigured: expected ${EXPECTED_CELLS} cells, found ${ACTUAL_CELLS:-0}." >&2
    exit 1
fi

# --- 4. Run the delivery matrix (RTMP/SRT x h264/h265) as a BLOCKING gate ------
echo "[pre-push] Running delivery matrix (clip=${CLIP_SECONDS}s) -- RTMP/SRT x h264/h265..."
OLR_E2E_CLIP_SECONDS="$CLIP_SECONDS" \
    ctest --test-dir "$DELIVERY_BUILD_DIR" -L delivery-gate \
        --output-on-failure --repeat until-pass:2 --no-tests=error
echo "[pre-push] Delivery matrix OK."

# Past here are the FAST pre-flight gates kept in the default push (~5 min) so
# PRs rarely fail CI on trivia: clang-tidy + the fast unit label on the build
# above. The slower e2e + sanitizer passes and the iOS build run in GitHub CI
# now -- opt into them locally with OLR_PREPUSH_FULL=1. OLR_PREPUSH_LIGHT=1 runs
# the delivery matrix only.
if [ "${OLR_PREPUSH_LIGHT:-0}" = "1" ]; then
    echo "[pre-push] OLR_PREPUSH_LIGHT=1 - delivery gate only; skipping clang-tidy + unit."
    exit 0
fi

QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-offscreen}"
export QT_QPA_PLATFORM

# Selectors kept verbatim so local == CI.
UNIT_SELECTOR_LE='sync-report|srt|native-apple-ingest|native-rtmp'
E2E_REGEX='^(e2e_record_stereo|e2e_record_mono|e2e_record_rational_fps|e2e_play_storm|e2e_play_seekplay|e2e_play_armedcut|e2e_play_playlist)$'

# --- 5. Fast unit label (-L ci) on the build above -- catches the unit failures
# CI would catch, at native speed, in ~1 min.
if [ "${SKIP_UNIT:-0}" = "1" ]; then
    echo "[pre-push] SKIP_UNIT=1 - skipping the unit gate."
else
    echo "[pre-push] Running unit suite (native, -L ci)..."
    ctest --test-dir "$DELIVERY_BUILD_DIR" --output-on-failure --repeat until-pass:2 \
        -L ci -LE "$UNIT_SELECTOR_LE"
    echo "[pre-push] Unit suite OK."
fi

# --- 6. clang-tidy on changed first-party C++ (was: build-test-macos clang-tidy) -
# Uses the delivery build's compile_commands.json. Pass 1 = whole changed file
# (config-driven WarningsAsErrors); Pass 2 = diff-scoped narrowing/widening gate.
# Skipped with a warning (not fatal) if LLVM clang-tidy is unavailable, matching
# the pre-commit hook's "partial toolchain does not block" policy.
if [ "${SKIP_TIDY:-0}" = "1" ]; then
    echo "[pre-push] SKIP_TIDY=1 - skipping clang-tidy gate."
else
    TIDY="$(command -v clang-tidy || true)"
    [ -x "$TIDY" ] || TIDY=/opt/homebrew/opt/llvm/bin/clang-tidy
    CTD="$(dirname "$TIDY")/../share/clang/clang-tidy-diff.py"
    if [ -x "$TIDY" ] && [ -f "$DELIVERY_BUILD_DIR/compile_commands.json" ]; then
        base="$(git merge-base HEAD origin/main 2>/dev/null \
                || git rev-parse HEAD~1 2>/dev/null || git rev-parse HEAD)"
        SDK="$(xcrun --show-sdk-path 2>/dev/null || true)"
        tidy_paths=('recorder_engine/*.cpp' 'playback/*.cpp' 'project/*.cpp'
                    'telemetry/*.cpp' 'websocket/*.cpp'
                    'settingsmanager.cpp' 'uimanager.cpp' 'midi/*.cpp')
        files="$(git diff --name-only "$base" HEAD -- "${tidy_paths[@]}" || true)"
        if [ -z "$files" ]; then
            echo "[pre-push] clang-tidy: no first-party C++ changes."
        else
            echo "[pre-push] Running clang-tidy on changed first-party C++..."
            printf '%s\n' "$files"
            rc=0
            # Pass 1 -- whole changed file (the high-signal bug classes are fatal).
            while IFS= read -r file; do
                [ -n "$file" ] || continue
                if [ -n "$SDK" ]; then
                    "$TIDY" -p "$DELIVERY_BUILD_DIR" --extra-arg=-isysroot --extra-arg="$SDK" "$file" || rc=1
                else
                    "$TIDY" -p "$DELIVERY_BUILD_DIR" "$file" || rc=1
                fi
            done <<< "$files"
            # Pass 2 -- diff-scoped integer-coercion gate (NEW occurrences fatal).
            if [ -f "$CTD" ]; then
                if [ -n "$SDK" ]; then
                    git diff -U0 "$base" HEAD -- "${tidy_paths[@]}" \
                        | python3 "$CTD" -p1 -path "$DELIVERY_BUILD_DIR" -clang-tidy-binary "$TIDY" \
                            -checks='-*,cppcoreguidelines-narrowing-conversions,bugprone-implicit-widening-of-multiplication-result' \
                            -warnings-as-errors='*' -extra-arg=-isysroot -extra-arg="$SDK" || rc=1
                else
                    git diff -U0 "$base" HEAD -- "${tidy_paths[@]}" \
                        | python3 "$CTD" -p1 -path "$DELIVERY_BUILD_DIR" -clang-tidy-binary "$TIDY" \
                            -checks='-*,cppcoreguidelines-narrowing-conversions,bugprone-implicit-widening-of-multiplication-result' \
                            -warnings-as-errors='*' || rc=1
                fi
            fi
            [ "$rc" -eq 0 ] || { echo "[pre-push] clang-tidy gate FAILED." >&2; exit 1; }
            echo "[pre-push] clang-tidy OK."
        fi
    else
        echo "[pre-push] clang-tidy skipped (no LLVM clang-tidy or compile_commands.json)." >&2
    fi
fi

# --- 7. OPT-IN heavy gates (OLR_PREPUSH_FULL): the e2e + sanitizer + iOS passes
# that GitHub CI now runs on every PR. Off by default to keep the push fast; run
# them to reproduce a CI failure locally or before a risky native/threading change.
if [ "${OLR_PREPUSH_FULL:-0}" != "1" ]; then
    exit 0
fi
echo "[pre-push] OLR_PREPUSH_FULL=1 - running e2e + sanitizers + full matrix + iOS."

# --- 7a. playback/record e2e at native speed (the native-timing scheduling run) -
if [ "${SKIP_E2E:-0}" = "1" ]; then
    echo "[pre-push] SKIP_E2E=1 - skipping native e2e."
else
    echo "[pre-push] Running playback e2e (native speed)..."
    OLR_E2E_CLIP_SECONDS="$CLIP_SECONDS" \
        ctest --test-dir "$DELIVERY_BUILD_DIR" --output-on-failure --repeat until-pass:3 \
            --no-tests=error -R "$E2E_REGEX"
    echo "[pre-push] Native e2e OK."
fi

# --- 7b. clang ASan+UBSan: unit + e2e (local repro of the CI sanitizers job) ----
# A separate -DOLR_SANITIZER build (cannot share the delivery binary). ASan/UBSan
# aborts are deterministic (abort_on_error/halt_on_error), so until-pass retries
# only paper over loopback timing flakes, never a real sanitizer finding.
if [ "${SKIP_ASAN:-0}" = "1" ]; then
    echo "[pre-push] SKIP_ASAN=1 - skipping ASan/UBSan gate."
else
    ASAN_BUILD_DIR="${OLR_PREPUSH_ASAN_BUILD_DIR:-build/prepush-asan}"
    echo "[pre-push] Building ASan+UBSan suite in ${ASAN_BUILD_DIR}..."
    cmake -S . -B "$ASAN_BUILD_DIR" -G Ninja \
        -DCMAKE_BUILD_TYPE=Debug \
        -DOLR_BUILD_TESTS=ON \
        -DOLR_WERROR=ON \
        -DOLR_SANITIZER="address;undefined" \
        -DCMAKE_PREFIX_PATH="$QT_HOST_PREFIX" >/dev/null
    cmake --build "$ASAN_BUILD_DIR"
    echo "[pre-push] Running unit suite under ASan+UBSan..."
    ASAN_OPTIONS="detect_leaks=0:abort_on_error=1" \
    UBSAN_OPTIONS="print_stacktrace=1:halt_on_error=1" \
        ctest --test-dir "$ASAN_BUILD_DIR" --output-on-failure --repeat until-pass:2 \
            -L unit -LE "$UNIT_SELECTOR_LE"
    echo "[pre-push] Running playback e2e under ASan+UBSan..."
    ASAN_OPTIONS="detect_leaks=0:abort_on_error=1" \
    UBSAN_OPTIONS="print_stacktrace=1:halt_on_error=1" \
    OLR_E2E_CLIP_SECONDS="$CLIP_SECONDS" \
        ctest --test-dir "$ASAN_BUILD_DIR" --output-on-failure --repeat until-pass:3 \
            --no-tests=error -R "$E2E_REGEX"
    echo "[pre-push] ASan+UBSan OK."
fi

# --- 7c. TSan: threading-sensitive playback/output cases -----------------------
if [ "${SKIP_TSAN:-0}" = "1" ]; then
    echo "[pre-push] SKIP_TSAN=1 - skipping TSan gate."
else
    TSAN_BUILD_DIR="${OLR_PREPUSH_TSAN_BUILD_DIR:-build/prepush-tsan}"
    TSAN_TARGETS=(tst_trackbuffer tst_audioframequeue tst_outputdispatcher
                  tst_outputruntime tst_commitgate tst_seekcoalescer tst_outputbusengine
                  tst_ndiingest)
    echo "[pre-push] Building TSan threading targets in ${TSAN_BUILD_DIR}..."
    cmake -S . -B "$TSAN_BUILD_DIR" -G Ninja \
        -DCMAKE_BUILD_TYPE=Debug \
        -DOLR_BUILD_TESTS=ON \
        -DOLR_SANITIZER="thread" \
        -DCMAKE_PREFIX_PATH="$QT_HOST_PREFIX" >/dev/null
    cmake --build "$TSAN_BUILD_DIR" --target "${TSAN_TARGETS[@]}"
    echo "[pre-push] Running threading tests under TSan..."
    TSAN_OPTIONS="halt_on_error=1" \
        ctest --test-dir "$TSAN_BUILD_DIR" --output-on-failure --repeat until-pass:2 \
            -R '^(tst_trackbuffer|tst_audioframequeue|tst_outputdispatcher|tst_outputruntime|tst_commitgate|tst_seekcoalescer|tst_outputbusengine|tst_ndiingest)$'
    echo "[pre-push] TSan OK."
fi

# --- 7d. Full local CTest matrix (everything except the local-only labels) -----
if [ "${SKIP_FULL_TESTS:-0}" = "1" ]; then
    echo "[pre-push] SKIP_FULL_TESTS=1 - skipping full local CTest gate."
else
    TEST_BUILD_DIR="${OLR_PREPUSH_TEST_BUILD_DIR:-build/prepush-tests}"
    CTEST_JOBS="${CTEST_PARALLEL_LEVEL:-$(sysctl -n hw.ncpu 2>/dev/null || echo 2)}"

    echo "[pre-push] Running full local CTest gate in ${TEST_BUILD_DIR}..."
    cmake -S . -B "$TEST_BUILD_DIR" -G Ninja \
        -DCMAKE_BUILD_TYPE=Debug \
        -DCMAKE_PREFIX_PATH="$QT_HOST_PREFIX" \
        -DOLR_BUILD_TESTS=ON >/dev/null
    cmake --build "$TEST_BUILD_DIR"
    ctest --test-dir "$TEST_BUILD_DIR" --output-on-failure \
        --repeat until-pass:2 --parallel "$CTEST_JOBS" \
        -LE 'sync-report|srt|native-apple-ingest|output-soak|ndi-output'
    echo "[pre-push] Full local CTest gate OK."
fi

if [ "${SKIP_IOS_BUILD:-0}" = "1" ]; then
    echo "[pre-push] SKIP_IOS_BUILD=1 - skipping iOS build."
    exit 0
fi

# Locate the Qt iOS kit. Override via env if your Qt lives elsewhere, e.g.
# QT_IOS_PREFIX=~/Qt/6.9.0/ios.
QT_IOS_PREFIX="${QT_IOS_PREFIX:-$HOME/Qt/6.10.1/ios}"
QT_CMAKE="$QT_IOS_PREFIX/bin/qt-cmake"

if [ ! -x "$QT_CMAKE" ]; then
    echo "[pre-push] Qt iOS kit not found at $QT_IOS_PREFIX - skipping iOS build."
    echo "[pre-push] (set QT_IOS_PREFIX/QT_HOST_PREFIX to enable; push allowed.)"
    exit 0
fi

echo "[pre-push] Building iOS (FFmpeg deps cached in ios_build/xcframeworks; first run ~20 min)..."
BUILD_DIR="build/ios-prepush"

"$QT_CMAKE" -S . -B "$BUILD_DIR" -G Xcode \
    -DQT_HOST_PATH="$QT_HOST_PREFIX" \
    -DCMAKE_OSX_ARCHITECTURES=arm64 >/dev/null

if cmake --build "$BUILD_DIR" --config Debug -- \
        CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO; then
    echo "[pre-push] iOS build OK - push proceeding."
else
    echo "[pre-push] iOS build FAILED - push aborted (SKIP_IOS_BUILD=1 to override)." >&2
    exit 1
fi
